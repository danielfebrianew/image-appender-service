                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/images/{{image_id}}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/images/{{image_id}}",
            "description": "Serve file image by image_id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns image content-type', function () { pm.expect(pm.response.headers.get('content-type')).to.match(/^image\\//); });"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/images/{{image_id}}",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/images/{{image_id}}",
            "description": "Soft delete image. Sebaiknya jalankan hanya untuk image test yang tidak dipakai project."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('deleted', function () { pm.expect(pm.response.json().status).to.eql('deleted'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "POST /api/projects",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"video_id\": \"{{video_id}}\",\n  \"name\": \"{{project_name}}\"\n}"
            },
            "url": "{{base_url}}/api/projects",
            "description": "Buat project baru dari video_id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('has project_id', function () { pm.expect(json.project_id).to.be.a('string'); });",
                  "pm.collectionVariables.set('project_id', json.project_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/projects",
            "description": "List projects."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/projects/{{project_id}}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/projects/{{project_id}}",
            "description": "Get full project JSON."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('project_id matches', function () { pm.expect(pm.response.json().project_id).to.eql(pm.collectionVariables.get('project_id')); });"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/projects/{{project_id}} - update timeline",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{project_name}}\",\n  \"layout\": {\n    \"image_area_ratio\": 0.30,\n    \"image_position\": \"bottom\",\n    \"image_fit\": \"cover\",\n    \"background_color\": \"#000000\"\n  },\n  \"click_sound\": {\n    \"enabled\": true,\n    \"asset\": \"click_default\",\n    \"volume\": 0.6,\n    \"trigger\": \"on_image_start\"\n  },\n  \"tracks\": [\n    {\n      \"id\": \"trk_001\",\n      \"image_id\": \"{{image_id}}\",\n      \"start_sec\": 0.0,\n      \"end_sec\": 4.5,\n      \"fit_override\": null\n    },\n    {\n      \"id\": \"trk_002\",\n      \"image_id\": \"{{image_id}}\",\n      \"start_sec\": 4.5,\n      \"end_sec\": 9.0,\n      \"fit_override\": null\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/api/projects/{{project_id}}",
            "description": "Update timeline project. Tracks boleh overlap, tapi body contoh dibuat non-overlap."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('tracks saved', function () { pm.expect(json.tracks).to.have.length.above(0); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Preview",
      "item": [
        {
          "name": "POST /api/preview",
          "request": {
            "method": "POST",
