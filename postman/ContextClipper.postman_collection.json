{
  "info": {
    "_postman_id": "7e63a045-2ce2-4f3a-91ce-contextclipper",
    "name": "ContextClipper Backend API",
    "description": "Postman collection untuk cek semua endpoint ContextClipper FastAPI. Jalankan request berurutan dari atas ke bawah agar variable seperti video_id, image_id, project_id, dan job_id otomatis terisi dari response.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "ws_base_url",
      "value": "ws://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "video_id",
      "value": "vid_replace_me",
      "type": "string"
    },
    {
      "key": "image_id",
      "value": "img_replace_me",
      "type": "string"
    },
    {
      "key": "project_id",
      "value": "prj_replace_me",
      "type": "string"
    },
    {
      "key": "job_id",
      "value": "job_replace_me",
      "type": "string"
    },
    {
      "key": "video_file_path",
      "value": "/absolute/path/to/source-video.mp4",
      "type": "string"
    },
    {
      "key": "image_file_path",
      "value": "/absolute/path/to/context-image.png",
      "type": "string"
    },
    {
      "key": "project_name",
      "value": "Episode 31 - segmen Tan Malaka",
      "type": "string"
    },
    {
      "key": "thumbnail_time",
      "value": "2.5",
      "type": "string"
    },
    {
      "key": "preview_timestamp",
      "value": "1.5",
      "type": "string"
    },
    {
      "key": "base64_image",
      "value": "data:image/png;base64,REPLACE_ME",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health",
            "description": "Cek server hidup."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('health ok', function () { pm.expect(pm.response.json().status).to.eql('ok'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Videos",
      "item": [
        {
          "name": "POST /api/videos - upload file",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{video_file_path}}"
                }
              ]
            },
            "url": "{{base_url}}/api/videos",
            "description": "Upload video source. Ganti collection variable video_file_path ke path lokal video."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('has video_id', function () { pm.expect(json.video_id).to.be.a('string'); });",
                  "pm.collectionVariables.set('video_id', json.video_id);",
                  "pm.collectionVariables.set('video_width', json.meta.width);",
                  "pm.collectionVariables.set('video_height', json.meta.height);",
                  "pm.collectionVariables.set('video_duration_sec', json.meta.duration_sec);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/videos - register disk path",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "path",
                  "value": "{{video_file_path}}",
                  "type": "text"
                },
                {
                  "key": "filename",
                  "value": "registered-source.mp4",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/videos",
            "description": "Register/copy video dari path lokal yang sudah ada di disk server."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('video_id', json.video_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/videos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/videos",
            "description": "List video yang tersedia."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/videos/{{video_id}}/thumbnail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/videos/{{video_id}}/thumbnail?t={{thumbnail_time}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "videos",
                "{{video_id}}",
                "thumbnail"
              ],
              "query": [
                {
                  "key": "t",
                  "value": "{{thumbnail_time}}"
                }
              ]
            },
            "description": "Ambil JPEG thumbnail pada timestamp tertentu."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('content-type image/jpeg', function () { pm.expect(pm.response.headers.get('content-type')).to.include('image/jpeg'); });"
                ]
              }
            }
          ]
        }
      ]
    },
