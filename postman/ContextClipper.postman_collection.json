              "raw": "{\n  \"video_id\": \"{{video_id}}\",\n  \"timestamp\": {{preview_timestamp}},\n  \"overlay\": {\n    \"image_id\": \"{{image_id}}\",\n    \"fit\": \"cover\"\n  }\n}"
            },
            "url": "{{base_url}}/api/preview",
            "description": "Generate composite JPEG satu frame."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('content-type image/jpeg', function () { pm.expect(pm.response.headers.get('content-type')).to.include('image/jpeg'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Render",
      "item": [
        {
          "name": "POST /api/render",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{project_id}}\"\n}"
            },
            "url": "{{base_url}}/api/render",
            "description": "Start render job. Response menyimpan job_id ke collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('has job_id', function () { pm.expect(json.job_id).to.be.a('string'); });",
                  "pm.collectionVariables.set('job_id', json.job_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/render/{{job_id}}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/render/{{job_id}}",
            "description": "Poll status render: queued, running, done, atau error."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('has valid status', function () { pm.expect(['queued', 'running', 'done', 'error']).to.include(json.status); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/render/{{job_id}}/download",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/render/{{job_id}}/download",
            "description": "Download MP4 output. Jalankan setelah status render done."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 when done', function () { pm.response.to.have.status(200); });",
                  "pm.test('content-type video/mp4', function () { pm.expect(pm.response.headers.get('content-type')).to.include('video/mp4'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "WebSocket",
      "item": [
        {
          "name": "WS /ws/render/{{job_id}}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ws_base_url}}/ws/render/{{job_id}}",
            "description": "Endpoint WebSocket render log. Di Postman, buka New > WebSocket Request lalu pakai URL ini: {{ws_base_url}}/ws/render/{{job_id}}"
          }
        }
      ]
    }
  ]
