          "name": "GET /api/images",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/images",
            "description": "List image library."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
